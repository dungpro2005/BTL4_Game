[node name="AboutLabel" type="Label" parent="PopupAbout/VBox2"]
text = "NEXUS CLASH\n\nGame thẻ bài chiến thuật 1v1 (Player vs AI)\nLấy cảm hứng từ Legends of Runeterra\n\nMục tiêu: Phá Nexus (20 HP) của đối phương\n• Unit / Spell / Champion\n• Attack token đổi mỗi round\n• Mana tăng theo round (tối đa 10)\n• 5 unit tối đa trên sân mỗi bên\n• AI heuristic rule-based"
autowrap_mode = 3
theme_override_font_sizes/font_size = 13

